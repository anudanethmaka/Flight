{
  "name": "skylink-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently \"tsc -b -w\" \"node --watch services/gateway/dist/index.js\" \"node --watch services/auth-service/dist/index.js\" \"node --watch services/flight-service/dist/index.js\" \"node --watch services/booking-service/dist/index.js\" \"node --watch services/notification-service/dist/index.js\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
